# Neon PostgreSQL Database (Required)
DATABASE_URL=postgresql://user:password@host.neon.tech/database

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Cron Job Secret (for daily mining triggers from CronJob.org)
CRON_SECRET=your-cron-secret-min-32-chars

# NOWPayments Integration
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret

# SendGrid Email Service
SENDGRID_API_KEY=your-sendgrid-api-key

# Application Settings
NODE_ENV=production
ADMIN_EMAIL=admin@your-domain.com
ENVIRONMENT=production
DISABLE_SENDGRID=false
DEBUG_MODE=false
PING_MESSAGE=pong

# Builder.io Configuration
VITE_PUBLIC_BUILDER_KEY=your-builder-io-public-key

# Netlify Function URL (for external services to call mining function)
NETLIFY_FUNCTION_URL=https://your-domain.netlify.app/.netlify/functions
